# Copy to .env.local and fill in. Never commit real secrets — .env files are gitignored.

# Public canonical site URL (used for SEO: metadata, sitemap, robots, JSON-LD).
NEXT_PUBLIC_SITE_URL=https://oridorjewelry.com

# --- Shopify Storefront (public; safe to expose to the browser) ---
# The Storefront API endpoint runs on the myshopify.com domain (most reliable).
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Branded checkout domain — the custom domain the cart/checkout redirect uses
# (so shoppers never see *.myshopify.com). Defaults to shop.oridorjewelry.com.
NEXT_PUBLIC_SHOPIFY_CHECKOUT_DOMAIN=shop.oridorjewelry.com

# --- Server-only secrets: never prefix these with NEXT_PUBLIC_ ---
# SHOPIFY_ADMIN_API_ACCESS_TOKEN=
