# Copy to .env.local and fill in. Never commit real secrets — .env files are gitignored.

# Public canonical site URL (used for SEO: metadata, sitemap, robots, JSON-LD).
NEXT_PUBLIC_SITE_URL=https://oridor.co.il

# --- Future integrations (leave blank until wired up) ---
# Server-only secrets: never prefix these with NEXT_PUBLIC_ (that exposes them to the browser).
# SHOPIFY_STORE_DOMAIN=
# SHOPIFY_STOREFRONT_API_TOKEN=
# SHOPIFY_ADMIN_API_TOKEN=
